{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranches": ["main"],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchPackagePatterns": ["k8s.io/*", "sigs.k8s.io/*"],
      "groupName": "k8s"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "actions"
    }
  ]
}
